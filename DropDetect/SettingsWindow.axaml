<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DropDetect.ViewModels"
        x:CompileBindings="True"
        x:DataType="vm:MainWindowViewModel"
        x:Class="DropDetect.SettingsWindow"
        Title="Configuration &amp; Export Tools"
        SizeToContent="WidthAndHeight"
        MinWidth="850" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource ThemeBackgroundBrush}"
        Icon="avares://Detectvbdc12.2/Assets/appaivbdc.ico"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{Binding LayoutFontScale}" ScaleY="{Binding LayoutFontScale}"/>
        </LayoutTransformControl.LayoutTransform>
        
        <Grid RowDefinitions="35,*,Auto">
            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1">
                <TextBlock Text="⚙️ DropDetect System Configuration" Margin="15,0" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
            </Border>

            <TabControl Grid.Row="1" TabStripPlacement="Left" Background="{DynamicResource ThemePanelBrush}">
                <!-- 1. AI Models & Capture -->
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="🧠 AI &amp; Capture" FontSize="14" Margin="5"/>
                    </TabItem.Header>
                    <Border Background="{DynamicResource ThemeBackgroundBrush}" Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="15">
                                <TextBlock Text="Model Management" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontWeight="Bold" FontSize="16"/>
                                
                                <Grid ColumnDefinitions="*,15,*" RowDefinitions="Auto,Auto">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Lens 4x Model:" FontSize="12" Margin="0,0,0,5"/>
                                        <ComboBox ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding SelectedModelPath4x}" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Lens 10x Model:" FontSize="12" Margin="0,0,0,5"/>
                                        <ComboBox ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding SelectedModelPath10x}" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnDefinitions="*,15,*">
                                    <Button Grid.Column="0" Content="📥 Import ONNX File" Command="{Binding ImportModelCommand}" 
                                            Background="{DynamicResource ThemeAccentGreenBrush}" Foreground="White" 
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="8"/>
                                    <Button Grid.Column="2" Content="📁 Open Models Folder" Command="{Binding OpenModelsFolderCommand}" 
                                            Background="{DynamicResource ThemeSubPanelBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                </Grid>

                                <Separator Background="{DynamicResource ThemeBorderBrush}" Margin="0,10"/>

                                <TextBlock Text="Capture Settings" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontWeight="Bold" FontSize="16"/>
                                
                                <Grid ColumnDefinitions="*,15,*">
                                    <StackPanel Grid.Column="0" Spacing="5">
                                        <TextBlock Text="{Binding LocSnapshotHotkeyLabel}" FontSize="12"/>
                                        <Button Content="{Binding SnapshotHotkeyDisplay}" Command="{Binding StartListeningForSnapshotHotkeyCommand}"
                                                Background="{Binding IsListeningForSnapshotHotkey, Converter={x:Static vm:MainWindowViewModel.HotkeyButtonBrushConverter}}"
                                                Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                        
                                        <TextBlock Text="{Binding LocLiveAiHotkeyLabel}" FontSize="12" Margin="0,10,0,0"/>
                                        <Button Content="{Binding LiveAiHotkeyDisplay}" Command="{Binding StartListeningForLiveAiHotkeyCommand}"
                                                Background="{Binding IsListeningForLiveAiHotkey, Converter={x:Static vm:MainWindowViewModel.HotkeyButtonBrushConverter}}"
                                                Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                                
                                        <TextBlock Text="{Binding HotkeyConflictMessage}" Foreground="{DynamicResource ThemeAccentRedBrush}" FontSize="11" FontWeight="Bold" IsVisible="{Binding HotkeyConflictMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="5">
                                        <TextBlock Text="{Binding LocAiConfidenceThreshold}" FontSize="12"/>
                                        <Slider Minimum="0.1" Maximum="0.9" Value="{Binding ConfidenceThreshold}" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                                        <TextBlock Text="{Binding ConfidenceThreshold, StringFormat='{}{0:F2}'}" HorizontalAlignment="Right" FontSize="12" Opacity="0.7"/>
                                        
                                        <TextBlock Text="{Binding LocSnapshotHoldDuration}" FontSize="12" Margin="0,5,0,0"/>
                                        <NumericUpDown Value="{Binding SnapshotFreezeDurationSeconds}" Minimum="0.5" Maximum="10.0" Increment="0.5" FormatString="0.0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <!-- 2. Hardware -->
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="🖥️ Hardware &amp; Camera" FontSize="14" Margin="5"/>
                    </TabItem.Header>
                    <Border Background="{DynamicResource ThemeBackgroundBrush}" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="System Hardware &amp; Performance" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontWeight="Bold" FontSize="16"/>
                            
                            <Border Background="{DynamicResource ThemeSubPanelBrush}" CornerRadius="8" Padding="10">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="2*,*,Auto" Margin="5,0">
                                        <TextBlock Text="Device Name" FontWeight="Bold" FontSize="12" Opacity="0.7"/>
                                        <TextBlock Grid.Column="1" Text="Type" FontWeight="Bold" FontSize="12" Opacity="0.7"/>
                                        <TextBlock Grid.Column="2" Text="Performance" FontWeight="Bold" FontSize="12" Opacity="0.7"/>
                                    </Grid>
                                    <Separator Background="{DynamicResource ThemeBorderBrush}"/>
                                    <ItemsControl ItemsSource="{Binding HardwareDevices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:HardwareDevice">
                                                <Grid ColumnDefinitions="2*,*,Auto" Margin="5,4">
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="12"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Type}" VerticalAlignment="Center" FontSize="12"/>
                                                    <Border Grid.Column="2" Background="{Binding PerformanceColor}" CornerRadius="4" Padding="8,2">
                                                        <TextBlock Text="{Binding Performance}" Foreground="Black" FontWeight="Bold" FontSize="11"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{Binding LocExecutionProvider}" FontSize="12" Margin="0,5,0,0"/>
                            <ComboBox ItemsSource="{Binding AvailableHardware}" SelectedItem="{Binding SelectedHardware}" HorizontalAlignment="Stretch"/>

                            <Separator Background="{DynamicResource ThemeBorderBrush}" Margin="0,10"/>
                            
                            <TextBlock Text="Camera Configuration" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontWeight="Bold" FontSize="16"/>
                            
                            <Grid ColumnDefinitions="*,15,*">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding LocCameraBackendApi}" FontSize="12" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding AvailableCameraApis}" SelectedItem="{Binding SelectedCameraApi}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding LocCameraResolution}" FontSize="12" Margin="0,0,0,5"/>
                                    <ComboBox ItemsSource="{Binding AvailableResolutions}" SelectedItem="{Binding CameraResolution}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- 3. Appearance -->
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="🎨 Appearance" FontSize="14" Margin="5"/>
                    </TabItem.Header>
                    <Border Background="{DynamicResource ThemeBackgroundBrush}" Padding="20">
                        <StackPanel Spacing="15">
                            <TextBlock Text="UI &amp; Themes" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontWeight="Bold" FontSize="16"/>
                            
                            <TextBlock Text="Interface Scale:" FontSize="12"/>
                            <Slider Minimum="0.8" Maximum="1.5" Value="{Binding LayoutFontScale}" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding LayoutFontScale, StringFormat='{}{0:F1}x'}" HorizontalAlignment="Right" FontSize="12" Opacity="0.7"/>

                            <TextBlock Text="Theme:" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding AvailableThemes}" SelectedItem="{Binding SelectedTheme}" HorizontalAlignment="Stretch"/>

                            <TextBlock Text="Language:" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding AvailableLanguages}" SelectedItem="{Binding SelectedLanguage}" HorizontalAlignment="Stretch"/>

                            <TextBlock Text="UI Font:" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding AvailableFonts}" SelectedItem="{Binding SelectedFont}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="15,10" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                    <Button Grid.Column="0" Content="Restore Defaults" Command="{Binding RestoreDefaultsCommand}" Background="Transparent" Foreground="{DynamicResource ThemeAccentRedBrush}"/>
                    <TextBlock Grid.Column="1" Text="⚠️ You have unsaved changes" Foreground="{DynamicResource ThemeAccentYellowBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0" IsVisible="{Binding HasUnsavedChanges}"/>
                    <Button Grid.Column="2" Content="Cancel" Command="{Binding AskCloseSettingsCommand}" Background="Transparent" Margin="0,0,10,0"/>
                    <Button Grid.Column="3" Content="Apply" Command="{Binding ApplySettingsCommand}" Background="{DynamicResource ThemeSubPanelBrush}" Margin="0,0,10,0" IsEnabled="{Binding HasUnsavedChanges}"/>
                    <Button Grid.Column="4" Content="Save &amp; Close" Command="{Binding ApplySettingsCommand}" Classes="accent" IsEnabled="{Binding HasUnsavedChanges}">
                        <Button.Flyout>
                            <!-- We can use a flyout or rely on the View Model closing logic -->
                        </Button.Flyout>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </LayoutTransformControl>
</Window>
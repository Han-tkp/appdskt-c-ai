<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DropDetect.ViewModels"
        x:CompileBindings="True"
        x:DataType="vm:MainWindowViewModel"
        x:Class="DropDetect.SettingsWindow"
        Title="Configuration &amp; Export Tools"
        SizeToContent="WidthAndHeight"
        MinWidth="750" MinHeight="450"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource ThemeBackgroundBrush}"
        Icon="avares://Detectvbdc12.2/Assets/appaivbdc.ico"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <!-- Hide native scrollviewer from inside, user requested no scrolling. 
         Using a layout that exactly fits the dimensions. -->
    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{Binding LayoutFontScale}" ScaleY="{Binding LayoutFontScale}"/>
        </LayoutTransformControl.LayoutTransform>
        
        <Grid RowDefinitions="35,*">
        
        <!-- Custom Title Bar (leaves minimize/close buttons handled by OS, removes the big close button below) -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}" 
                BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1"
                IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10" Margin="15,0,0,0">
                <TextBlock Text="⚙️ Configuration &amp; Export Tools" 
                           Foreground="{DynamicResource ThemeTextPrimaryBrush}" 
                           FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Sidebar Layout with TabStripPlacement -->
        <TabControl Grid.Row="1" TabStripPlacement="Left" Background="{DynamicResource ThemePanelBrush}">
            
            <TabControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="5" Margin="10,15"/>
                </ItemsPanelTemplate>
            </TabControl.ItemsPanel>
            
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="12,10"/>
                    <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
                <Style Selector="TabItem:selected">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeAccentBlueBrush}"/>
                    <Setter Property="Background" Value="#1A89b4fa"/>
                </Style>
            </TabControl.Styles>

            <!-- 1. File Management -->
            <TabItem Header="📁 File Management">
                <Border Background="{DynamicResource ThemeBackgroundBrush}" CornerRadius="0,0,8,0" Padding="20">
                    <StackPanel Spacing="15">
                        <TextBlock Text="{Binding LocFileStoragePath}" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontWeight="Bold" FontSize="16"/>
                        
                        <Border Background="{DynamicResource ThemeSubPanelBrush}" CornerRadius="6" Padding="12" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding LocCurrentOutputDir}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding OutputDirectory}" Foreground="{Binding OutputDirectoryColor}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Button Content="{Binding LocBtnChangeOutputDir}" Command="{Binding SelectDirectoryCommand}" 
                                Background="{DynamicResource ThemeAccentBlueBrush}" Foreground="{DynamicResource ThemeActionTextBrush}" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Padding="10" Margin="0,10,0,0"/>
                        
                        <Button Content="{Binding LocBtnSaveSnapshot}" Command="{Binding SaveSnapshotCommand}" 
                                Background="{DynamicResource ThemeAccentYellowBrush}" Foreground="{DynamicResource ThemeActionTextBrush}" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Padding="10"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 2. Hardware -->
            <TabItem Header="🖥️ Hardware">
                <Border Background="{DynamicResource ThemeBackgroundBrush}" CornerRadius="0,0,8,0" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding LocHardwareAcceleration}" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontWeight="Bold" FontSize="16"/>

                        <StackPanel Spacing="5" MaxWidth="400" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding LocExecutionProvider}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding AvailableHardware}" SelectedItem="{Binding SelectedHardware}" HorizontalAlignment="Stretch"/>
                            
                            <TextBlock Text="{Binding LocCameraBackendApi}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12" Margin="0,10,0,0"/>
                            <ComboBox ItemsSource="{Binding AvailableCameraApis}" SelectedItem="{Binding SelectedCameraApi}" HorizontalAlignment="Stretch"/>

                            <TextBlock Text="{Binding LocCameraResolution}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12" Margin="0,10,0,0"/>
                            <ComboBox ItemsSource="{Binding AvailableResolutions}" SelectedItem="{Binding CameraResolution}" HorizontalAlignment="Stretch"/>

                            <TextBlock Text="{Binding LocSystemHardwareInfo}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12" Margin="0,15,0,0"/>
                            <Border Background="#10FFFFFF" CornerRadius="4" Padding="8" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                                <TextBlock Text="{Binding CurrentHardwareSpecs}" Foreground="{DynamicResource ThemeAccentYellowBrush}" FontSize="11" TextWrapping="Wrap" MinHeight="30" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 2.5 AI Settings -->
            <TabItem Header="🧠 AI Settings">
                <Border Background="{DynamicResource ThemeBackgroundBrush}" CornerRadius="0,0,8,0" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="AI Engine &amp; Models" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontWeight="Bold" FontSize="16"/>

                        <Grid ColumnDefinitions="*,20,*">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="ONNX Model (4x Lens):" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding SelectedModelPath4x}" HorizontalAlignment="Stretch"/>

                                <TextBlock Text="ONNX Model (10x Lens):" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12" Margin="0,10,0,0"/>
                                <ComboBox ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding SelectedModelPath10x}" HorizontalAlignment="Stretch"/>

                                <!-- Import / Refresh Area -->
                                <Border Background="#10FFFFFF" CornerRadius="4" Padding="12" Margin="0,15,0,0" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Model Management / การจัดการไฟล์โมเดล:" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="To add or remove models, open the folder and drop .onnx files inside. (เพิ่ม/ลบโมเดลโดยเปิดโฟลเดอร์นี้)" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" TextWrapping="Wrap"/>
                                        <Grid ColumnDefinitions="*,10,*">
                                            <Button Grid.Column="0" Content="📂 Open Folder" Command="{Binding OpenModelsFolderCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="{DynamicResource ThemePanelBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="12" Padding="5"/>
                                            <Button Grid.Column="2" Content="🔄 Refresh List" Command="{Binding RefreshModelsCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="{DynamicResource ThemePanelBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="12" Padding="5"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" Spacing="5">
                                <TextBlock Text="{Binding LocAiConfidenceThreshold}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12"/>
                                <Slider Minimum="0.1" Maximum="0.9" Value="{Binding ConfidenceThreshold}" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                                <TextBlock Text="{Binding ConfidenceThreshold, StringFormat='{}{0:F2}'}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" HorizontalAlignment="Right" FontSize="12"/>

                                <TextBlock Text="{Binding LocSnapshotHotkey}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12" Margin="0,5,0,0"/>
                                <ComboBox ItemsSource="{Binding AvailableHotkeys}" SelectedItem="{Binding SnapshotHotkey}" HorizontalAlignment="Stretch"/>

                                <TextBlock Text="{Binding LocSnapshotHoldDuration}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12" Margin="0,10,0,0"/>
                                <ComboBox SelectedItem="{Binding SnapshotFreezeDurationMs}" HorizontalAlignment="Stretch">
                                    <ComboBox.Items>
                                        <x:Int32>500</x:Int32>
                                        <x:Int32>1000</x:Int32>
                                        <x:Int32>1500</x:Int32>
                                        <x:Int32>2000</x:Int32>
                                        <x:Int32>3000</x:Int32>
                                        <x:Int32>5000</x:Int32>
                                    </ComboBox.Items>
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat='{}{0} ms'}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 3. Themes -->
            <TabItem Header="🎨 Themes">
                <Border Background="{DynamicResource ThemeBackgroundBrush}" CornerRadius="0,0,8,0" Padding="20">
                    <StackPanel Spacing="15">
                        <TextBlock Text="{Binding LocAppearanceSettings}" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontWeight="Bold" FontSize="16"/>
                        
                        <TextBlock Text="{Binding LocColorTheme}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12"/>
                        <ComboBox ItemsSource="{Binding AvailableThemes}" SelectedItem="{Binding SelectedTheme}" HorizontalAlignment="Stretch"/>

                        <TextBlock Text="UI Font / แบบอักษรโปรแกรม:" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12" Margin="0,10,0,0"/>
                        <ComboBox ItemsSource="{Binding AvailableFonts}" SelectedItem="{Binding SelectedFont}" HorizontalAlignment="Stretch"/>

                        <TextBlock Text="Language / ภาษา:" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12" Margin="0,10,0,0"/>
                        <ComboBox ItemsSource="{Binding AvailableLanguages}" SelectedItem="{Binding SelectedLanguage}" HorizontalAlignment="Stretch"/>

                        <TextBlock Text="UI Scale / ปรับขนาดหน้าจอ:" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12" Margin="0,10,0,0"/>
                        <Grid ColumnDefinitions="*,50">
                            <Slider Grid.Column="0" Minimum="0.5" Maximum="2.0" Value="{Binding LayoutFontScale}" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                            <TextBlock Grid.Column="1" Text="{Binding LayoutFontScale, StringFormat='{}{0:F2}x'}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>

        </TabControl>
        </Grid>
    </LayoutTransformControl>

</Window>

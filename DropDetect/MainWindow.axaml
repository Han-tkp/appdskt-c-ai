<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DropDetect.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="DropDetect.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="avares://Detectvbdc12.2/Assets/appaivbdc.ico"
        Title="DropDetect - WHO Standard Droplet Analysis"
        Background="{DynamicResource ThemeBackgroundBrush}"
        WindowState="Maximized"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.KeyBindings>
        <KeyBinding Gesture="{Binding SnapshotHotkey}" Command="{Binding TakeSnapshotCommand}"/>
        <KeyBinding Gesture="{Binding LiveAiHotkey}" Command="{Binding AnalyzeCommand}"/>
    </Window.KeyBindings>

    <LayoutTransformControl>
        <LayoutTransformControl.LayoutTransform>
            <ScaleTransform ScaleX="{Binding LayoutFontScale}" ScaleY="{Binding LayoutFontScale}"/>
        </LayoutTransformControl.LayoutTransform>

        <Grid RowDefinitions="35,30,Auto,*">
        <!-- Row 0: Custom Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePanelBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1"
                IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10" Margin="15,0,0,0">
                <Image Source="avares://Detectvbdc12.2/Assets/appaivbdc.ico" Width="18" Height="18" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                <TextBlock Text="{Binding ProjectTitleDisplay, StringFormat='DropDetect — {0}'}"
                           Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                           FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Row 1: Menu Bar -->
        <Border Grid.Row="1" Background="{DynamicResource ThemePanelBrush}" BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1">
            <Menu Background="Transparent">
                <MenuItem Header="_File">
                    <MenuItem Header="_New Project..." Command="{Binding NewProjectCommand}" InputGesture="Ctrl+N"/>
                    <MenuItem Header="_Open Project..." Command="{Binding OpenProjectCommand}" InputGesture="Ctrl+O"/>
                    <Separator/>
                    <MenuItem Header="_Save Project" Command="{Binding SaveProjectCommand}" InputGesture="Ctrl+S"/>
                    <MenuItem Header="Save _As New Project..." Command="{Binding SaveProjectAsCommand}" InputGesture="Ctrl+Shift+S"/>
                    <Separator/>
                    <MenuItem Header="_Export Excel Data..." Command="{Binding ExportExcelCommand}"/>
                    <Separator/>
                    <MenuItem Header="_Exit" Click="ExitApp_Click"/>
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="_Settings &amp; Tools" Command="{Binding ToggleSettingsCommand}"/>
                </MenuItem>
            </Menu>
        </Border>

        <!-- Row 2: Dashboard Navigation Bar -->
        <Border Grid.Row="2" Background="{DynamicResource ThemePanelBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid ColumnDefinitions="Auto,1,Auto,1,Auto,1,Auto,1,Auto,1,Auto,1,Auto,1,Auto,1,Auto,*,Auto">

                <!-- WHO Badge -->
                <Border Grid.Column="0" Background="{Binding WhoPassColor}" CornerRadius="5" Padding="12,4" VerticalAlignment="Center">
                    <TextBlock Text="{Binding WhoPassText}" FontWeight="Bold" FontSize="13" Foreground="#1e1e2e" VerticalAlignment="Center"/>
                </Border>

                <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource ThemeBorderBrush}" Margin="8,2"/>

                <!-- Slide Name -->
                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="{Binding CurrentSlideLabel}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding SelectedSlide.SlideName, FallbackValue='—'}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontWeight="Bold" FontSize="14"/>
                </StackPanel>

                <Rectangle Grid.Column="3" Width="1" Fill="{DynamicResource ThemeBorderBrush}" Margin="8,2"/>

                <!-- Slide Status (Add to report?) -->
                <StackPanel Grid.Column="4" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="{Binding SlideStatusLabel}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding SelectedSlide.StatusText, FallbackValue='—'}" Foreground="{Binding SelectedSlide.StatusColor}" FontWeight="Bold" FontSize="13"/>
                </StackPanel>

                <Rectangle Grid.Column="5" Width="1" Fill="{DynamicResource ThemeBorderBrush}" Margin="8,2"/>

                <!-- Target Sample Size -->
                <StackPanel Grid.Column="6" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="{Binding TargetSizeLabel}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding TargetSampleSize}" Foreground="{DynamicResource ThemeAccentYellowBrush}" FontWeight="Bold" FontSize="14"/>
                </StackPanel>

                <Rectangle Grid.Column="7" Width="1" Fill="{DynamicResource ThemeBorderBrush}" Margin="8,2"/>

                <!-- VMD -->
                <StackPanel Grid.Column="8" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="{Binding VmdLabel}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding VmdText}" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontWeight="Bold" FontSize="14"/>
                </StackPanel>

                <Rectangle Grid.Column="9" Width="1" Fill="{DynamicResource ThemeBorderBrush}" Margin="8,2"/>

                <!-- In-Frame -->
                <StackPanel Grid.Column="10" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="{Binding InFrameLabel}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding DropletCount}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontWeight="Bold" FontSize="14"/>
                </StackPanel>

                <Rectangle Grid.Column="11" Width="1" Fill="{DynamicResource ThemeBorderBrush}" Margin="8,2"/>

                <!-- Accumulated -->
                <StackPanel Grid.Column="12" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="{Binding AccumulatedLabel}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding AccumulatedCount}" Foreground="{DynamicResource ThemeAccentGreenBrush}" FontWeight="Bold" FontSize="14"/>
                </StackPanel>

                <Rectangle Grid.Column="13" Width="1" Fill="{DynamicResource ThemeBorderBrush}" Margin="8,2"/>

                <!-- SPAN -->
                <StackPanel Grid.Column="14" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="{Binding SpanLabel}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding SpanText}" Foreground="#FAB387" FontWeight="Bold" FontSize="14"/>
                </StackPanel>

                <Rectangle Grid.Column="15" Width="1" Fill="{DynamicResource ThemeBorderBrush}" Margin="8,2"/>

                <!-- Out-of-Bounds -->
                <StackPanel Grid.Column="16" Orientation="Vertical" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="{Binding OutOfBoundsLabel}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="10"/>
                    <TextBlock Text="{Binding OutOfBoundsCount}" Foreground="{DynamicResource ThemeAccentRedBrush}" FontWeight="Bold" FontSize="14"/>
                </StackPanel>

                <!-- Warning indicator -->
                <Border Grid.Column="18" Background="{DynamicResource ThemeAccentRedBrush}" CornerRadius="4" Padding="8,3"
                        IsVisible="{Binding IsWarningVisible}" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="⚠️ &lt;200 drops" Foreground="{DynamicResource ThemeActionTextBrush}" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>

        <!-- Row 3: Main Content Area -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="420"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- ======= SIDEBAR ======= -->
            <Border Grid.Column="0" Background="{DynamicResource ThemePanelBrush}" Padding="5">
                <Grid RowDefinitions="*,Auto">
                    <TabControl Grid.Row="0" Background="Transparent">

                        <!-- Tab 1: Analyze -->
                        <TabItem Header="{Binding LocTabAnalyze}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="6" Margin="5,10,5,5">
                                <!-- Lens -->
                                <TextBlock Text="{Binding LocObjLens}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding AvailableLenses}" SelectedItem="{Binding LensSelection}" HorizontalAlignment="Stretch"/>

                                <!-- Camera Start/Stop/Switch -->
                                <Grid ColumnDefinitions="*,5,*,5,*" Margin="0,10,0,0">
                                    <Button Grid.Column="0" Content="▶ Start" Command="{Binding StartCameraCommand}"
                                            Background="{DynamicResource ThemeAccentGreenBrush}" Foreground="{DynamicResource ThemeActionTextBrush}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Padding="8"/>
                                    <Button Grid.Column="2" Content="🔄 Switch" Command="{Binding CycleCameraCommand}"
                                            Background="{DynamicResource ThemeSubPanelBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Padding="8"
                                            ToolTip.Tip="Switch to next camera index"/>
                                    <Button Grid.Column="4" Content="Stop" Command="{Binding StopCameraCommand}"
                                            Background="{DynamicResource ThemeAccentRedBrush}" Foreground="{DynamicResource ThemeActionTextBrush}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Padding="8"/>
                                </Grid>

                                <!-- Dynamic Action Buttons -->
                                <StackPanel Margin="0,10,0,0" Spacing="8">
                                    <Button Content="{Binding AnalyzeButtonText}" Command="{Binding AnalyzeCommand}"
                                            Background="{Binding AnalyzeButtonBackground}" Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Padding="8"/>
                                    <Button Content="{Binding SnapshotHotkeyDisplay, StringFormat='📸 Take Snapshot ({0})'}" Command="{Binding TakeSnapshotUICommand}"
                                            Background="{DynamicResource ThemeAccentBlueBrush}" Foreground="{DynamicResource ThemeActionTextBrush}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Padding="8"/>
                                </StackPanel>
                            </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- Tab 2: Report -->
                        <TabItem Header="{Binding LocTabReport}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="7" Margin="5,10,5,5">

                                <!-- µm Range Filter — text input only -->
                                <Border Background="{DynamicResource ThemeSubPanelBrush}" CornerRadius="8" Padding="10,8">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding LocFilterSizeUm}" FontWeight="Bold" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontSize="12"/>
                                        <Grid ColumnDefinitions="Auto,*,12,Auto,*">
                                            <TextBlock Grid.Column="0" Text="Min:" Foreground="{DynamicResource ThemeTextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                                            <TextBox Grid.Column="1" Text="{Binding FilterMinText}" HorizontalAlignment="Stretch"
                                                     Watermark="e.g. 5.0" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text=""/>
                                            <TextBlock Grid.Column="3" Text="Max:" Foreground="{DynamicResource ThemeTextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                                            <TextBox Grid.Column="4" Text="{Binding FilterMaxText}" HorizontalAlignment="Stretch"
                                                     Watermark="e.g. 30.0" TextAlignment="Center"/>
                                        </Grid>
                                        <Border Background="#20ffffff" CornerRadius="5" Padding="6,3">
                                            <TextBlock Text="{Binding FilterRangeLabel}" Foreground="{DynamicResource ThemeAccentGreenBrush}" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Slide Tracker -->
                                <TextBlock Text="{Binding LocSlideWorkflowTracker}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontWeight="SemiBold" FontSize="12"/>
                                <ListBox ItemsSource="{Binding SlideList}" SelectedItem="{Binding SelectedSlide}"
                                         Background="{DynamicResource ThemeSubPanelBrush}" CornerRadius="8" MinHeight="95">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SlideItemViewModel">
                                            <Grid ColumnDefinitions="*,Auto,Auto" Margin="2">
                                                <TextBlock Grid.Column="0" Text="{Binding SlideName}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" VerticalAlignment="Center" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding StatusText}" Foreground="{Binding StatusColor}" VerticalAlignment="Center" Margin="8,0"/>
                                                <Button Grid.Column="2" Content="🔄" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RetakeSlideCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource ThemeAccentRedBrush}" Padding="5,-5" IsVisible="{Binding IsAnalyzed}" ToolTip.Tip="Retake"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Sample Size -->
                                <TextBlock Text="{Binding TargetSizeLabel}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="12"/>
                                <NumericUpDown Value="{Binding TargetSampleSize}" Minimum="1" Maximum="10000" Increment="50" FormatString="0" HorizontalAlignment="Stretch"/>

                                <Button Content="{Binding LocBtnAddData}" Command="{Binding AddToReportCommand}"
                                        Background="{DynamicResource ThemeAccentGreenBrush}" Foreground="{DynamicResource ThemeActionTextBrush}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Margin="0,4,0,0"/>

                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding LocItemsInReport}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ReportItemCount}" Foreground="{DynamicResource ThemeAccentYellowBrush}" FontWeight="Bold" FontSize="15"/>
                                </Grid>

                                <!-- Output Dir -->
                                <Border Background="{DynamicResource ThemeSubPanelBrush}" CornerRadius="8" Padding="8,6">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding LocCurrentOutputDir}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding OutputDirectory}" Foreground="{Binding OutputDirectoryColor}" FontSize="11" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Button Content="{Binding LocBtnExportExcel}" Command="{Binding ExportExcelCommand}"
                                        Background="{DynamicResource ThemeAccentGreenBrush}" Foreground="{DynamicResource ThemeActionTextBrush}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" FontSize="14" Padding="8" Margin="0,4,0,4"/>
                            </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                    </TabControl>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Background="{DynamicResource ThemeBorderBrush}" ResizeDirection="Columns"/>

            <!-- ======= MAIN WORKSPACE ======= -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">

                <!-- Camera Status Bar (visual) -->
                <Border Grid.Row="0" Background="{DynamicResource ThemeSubPanelBrush}"
                        BorderBrush="{DynamicResource ThemeBorderBrush}" BorderThickness="0,0,0,1" Padding="12,7">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Camera status dot + text -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <!-- Live indicator dot -->
                            <Ellipse Width="9" Height="9" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{Binding CameraStatusColor}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding CameraStatusLabel}" Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Status message (main) -->
                        <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="12,0" TextTrimming="CharacterEllipsis"/>

                        <!-- Camera index badge -->
                        <Border Grid.Column="2" Background="{DynamicResource ThemeBorderBrush}" CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CameraIndex, StringFormat='CAM {0}'}"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Camera Display -->
                <Border Grid.Row="1" Background="Black" ClipToBounds="True">
                    <Panel>
                        <Image Source="{Binding CameraImage}" Stretch="Uniform" PointerPressed="CameraImage_PointerPressed"/>

                        <!-- Loading Overlay -->
                        <Border Background="#80000000" IsVisible="{Binding IsCameraLoading}">
                            <Border Background="{DynamicResource ThemeBorderBrush}" CornerRadius="25"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Padding="25,15" BoxShadow="0 4 15 0 #40000000">
                                <StackPanel Orientation="Horizontal" Spacing="15">
                                    <ProgressBar IsIndeterminate="True" Width="120" Height="12" CornerRadius="6"
                                                 Foreground="{DynamicResource ThemeAccentBlueBrush}"
                                                 Background="{DynamicResource ThemeBackgroundBrush}"/>
                                    <TextBlock Text="{Binding LoadingMessage}" Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                               VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                                </StackPanel>
                            </Border>
                        </Border>

                        <!-- Snapshot Bitmap Overlay: แสดง frame+labels จาก snapshot ทับบน live feed -->
                        <!-- IsVisible ถูกควบคุมผ่าน SnapshotOverlayBitmap (null = ซ่อน) -->
                        <Image Source="{Binding SnapshotOverlayBitmap}"
                               Stretch="Uniform"
                               Opacity="0.92"
                               IsVisible="{Binding IsSnapshotResultVisible}"
                               IsHitTestVisible="False"/>

                        <!-- Snapshot info badge มุมขวาบน -->
                        <Border IsVisible="{Binding IsSnapshotResultVisible}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,10,12,0" CornerRadius="10" Padding="14,10"
                                Background="#CC000000" BoxShadow="0 4 16 0 #60000000">
                            <StackPanel Spacing="4">
                                <TextBlock Text="📸 Snapshot" Foreground="#89dceb"
                                           FontWeight="Bold" FontSize="13"/>
                                <Grid ColumnDefinitions="Auto,8,Auto" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="VMD:" Foreground="#a6adc8" FontSize="12"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding VmdText, StringFormat='{}{0} µm'}"
                                               Foreground="#cba6f7" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="In-Frame:" Foreground="#a6adc8" FontSize="12"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding DropletCount}"
                                               Foreground="#a6e3a1" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Accumulated:" Foreground="#a6adc8" FontSize="12"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding AccumulatedCount}"
                                               Foreground="#fab387" FontWeight="Bold" FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Panel>
                </Border>

                <!-- Telemetry Bar -->
                <Border Grid.Row="2" Background="{DynamicResource ThemeSubPanelBrush}" Padding="12,5">
                    <TextBlock Text="{Binding TelemetryText}" Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                               FontSize="11" HorizontalAlignment="Right"/>
                </Border>
            </Grid>
        </Grid>
        </Grid>
    </LayoutTransformControl>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DropDetect.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="DropDetect.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="avares://DropDetect/Assets/appaivbdc.ico"
        Title="DropDetect - WHO Standard Droplet Analysis"
        Background="{DynamicResource ThemeBackgroundBrush}"
        WindowState="Maximized">

    <Panel>
        <Grid ColumnDefinitions="320, 5, *">
            <!-- Sidebar with Tabs -->
            <Border Grid.Column="0" Background="{DynamicResource ThemePanelBrush}" Padding="5">
                <Grid RowDefinitions="*,Auto">
                    <TabControl Grid.Row="0" Background="Transparent">
                    
                    <!-- Tab 1: Analyze -->
                    <TabItem Header="🔬 Analyze" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="16">
                        <StackPanel Spacing="8" Margin="5,15,5,0">
                            <TextBlock Text="Objective Lens Power:" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <ComboBox ItemsSource="{Binding AvailableLenses}" SelectedItem="{Binding LensSelection}" HorizontalAlignment="Stretch"/>

                            <TextBlock Text="Confidence Threshold:" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,5,0,0"/>
                            <Slider Minimum="0.1" Maximum="0.9" Value="{Binding ConfidenceThreshold}" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ConfidenceThreshold, StringFormat='{}{0:F2}'}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" HorizontalAlignment="Right"/>

                            <Grid ColumnDefinitions="*,10,*" Margin="0,10,0,0">
                                <Button Grid.Column="0" Content="▶ Start" Command="{Binding StartCameraCommand}" Background="{DynamicResource ThemeAccentGreenBrush}" Foreground="{DynamicResource ThemeActionTextBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold"/>
                                <Button Grid.Column="2" Content="⏹ Stop" Command="{Binding StopCameraCommand}" Background="{DynamicResource ThemeAccentRedBrush}" Foreground="{DynamicResource ThemeActionTextBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,10,*" Margin="0,8,0,0">
                                <Button Grid.Column="0" Content="🔄 Switch Camera" Command="{Binding CycleCameraCommand}" Background="{DynamicResource ThemeAccentBlueBrush}" Foreground="{DynamicResource ThemeActionTextBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold"/>
                                <Button Grid.Column="2" Content="{Binding AnalyzeButtonText}" Command="{Binding AnalyzeCommand}" Background="{DynamicResource ThemeAccentYellowBrush}" Foreground="{DynamicResource ThemeActionTextBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold"/>
                            </Grid>
                            
                            <Border Background="{DynamicResource ThemeAccentRedBrush}" CornerRadius="8" Padding="8" Margin="0,15,0,0" IsVisible="{Binding IsWarningVisible}">
                                <TextBlock Text="⚠️ Warning: Droplet count is below WHO 200 threshold recommendation." Foreground="{DynamicResource ThemeActionTextBrush}" TextWrapping="Wrap" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            
                            <!-- Real-Time Metrics Dashboard -->
                            <Border Background="{DynamicResource ThemeBorderBrush}" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="📊 Real-Time Dashboard" FontWeight="Bold" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontSize="16" HorizontalAlignment="Center"/>
                                    <Rectangle Height="1" Fill="{DynamicResource ThemeBorderBrush}" Margin="0,5"/>
                                    
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Current Frame Drops:" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,10,5"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DropletCount}" Foreground="{DynamicResource ThemeAccentYellowBrush}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Accumulated:" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,0,10,5" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AccumulatedCount}" Foreground="{DynamicResource ThemeAccentGreenBrush}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Right"/>
                                        
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="VMD (Dv0.5) µm:" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,10,5"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding VmdText}" Foreground="{DynamicResource ThemeAccentGreenBrush}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="SPAN:" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,10,5"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SpanText}" Foreground="#FAB387" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Evaluation:" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding EvaluationStatus}" Foreground="{DynamicResource ThemeAccentRedBrush}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </TabItem>

                    <!-- Tab 2: Report Lifecycle -->
                    <TabItem Header="📊 Report" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="16">
                        <StackPanel Spacing="8" Margin="5,15,5,0">
                            
                            <!-- Slide Workflow Tracker -->
                            <TextBlock Text="Slide Workflow Tracker:" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,10,0,0" FontWeight="SemiBold"/>
                            <ListBox ItemsSource="{Binding SlideList}" SelectedItem="{Binding SelectedSlide}" Background="{DynamicResource ThemeSubPanelBrush}" CornerRadius="8" Margin="0,5,0,10" MinHeight="140">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SlideItemViewModel">
                                        <Grid ColumnDefinitions="*,Auto,Auto" Margin="2">
                                            <TextBlock Grid.Column="0" Text="{Binding SlideName}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" VerticalAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding StatusText}" Foreground="{Binding StatusColor}" VerticalAlignment="Center" Margin="10,0"/>
                                            <Button Grid.Column="2" Content="🔄" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RetakeSlideCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="{DynamicResource ThemeAccentRedBrush}" Padding="5,-5" IsVisible="{Binding IsAnalyzed}" ToolTip.Tip="Retake this slide"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Text="Target Sample Size:" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,5,0,0"/>
                            <NumericUpDown Value="{Binding TargetSampleSize}" Minimum="1" Maximum="10000" Increment="50" FormatString="0" HorizontalAlignment="Stretch"/>
                            
                            <Button Content="➕ Add to Report" Command="{Binding AddToReportCommand}" Background="{DynamicResource ThemeAccentGreenBrush}" Foreground="{DynamicResource ThemeActionTextBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Margin="0,15,0,0"/>
                            
                            <Grid ColumnDefinitions="*,Auto" Margin="0,5,0,0">
                                <TextBlock Grid.Column="0" Text="Items in Report:" Foreground="{DynamicResource ThemeTextSecondaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding ReportItemCount}" Foreground="{DynamicResource ThemeAccentYellowBrush}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Right"/>
                            </Grid>
                            
                            <!-- Output Directory Status -->
                            <Border Background="{DynamicResource ThemeSubPanelBrush}" CornerRadius="8" Padding="10" Margin="0,15,0,0">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Output Directory:" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding OutputDirectory}" Foreground="{Binding OutputDirectoryColor}" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Button Content="💾 Export to Excel" Command="{Binding ExportExcelCommand}" Background="{DynamicResource ThemeAccentGreenBrush}" Foreground="{DynamicResource ThemeActionTextBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Margin="0,15,0,0" FontSize="16" Padding="10"/>
                        </StackPanel>
                    </TabItem>

                </TabControl>
                <!-- Popup Trigger -->
                <Button Grid.Row="1" Content="⚙️ Settings &amp; Tools" Command="{Binding ToggleSettingsCommand}" Background="{DynamicResource ThemeSubPanelBrush}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Margin="5"/>
            </Grid>
            </Border>

            <!-- Adjustable Splitter -->
            <GridSplitter Grid.Column="1" Background="{DynamicResource ThemeBorderBrush}" ResizeDirection="Columns"/>

            <!-- Main Workspace -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0" Background="{DynamicResource ThemeSubPanelBrush}" Padding="15">
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                </Border>
                
                <Border Grid.Row="1" Background="{DynamicResource ThemeActionTextBrush}" Margin="20" CornerRadius="10" ClipToBounds="True">
                    <Panel>
                        <Image Source="{Binding CameraImage}" Stretch="Uniform"/>
                        
                        <!-- Camera & AI Loading Overlay -->
                        <Border Background="#80000000" IsVisible="{Binding IsCameraLoading}">
                            <Border Background="{DynamicResource ThemeBorderBrush}" CornerRadius="25" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="25,15" BoxShadow="0 4 15 0 #40000000">
                                <StackPanel Orientation="Horizontal" Spacing="15">
                                    <ProgressBar IsIndeterminate="True" Width="120" Height="12" CornerRadius="6" Foreground="{DynamicResource ThemeAccentBlueBrush}" Background="{DynamicResource ThemeBackgroundBrush}"/>
                                    <TextBlock Text="{Binding LoadingMessage}" Foreground="{DynamicResource ThemeTextPrimaryBrush}" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                                </StackPanel>
                            </Border>
                        </Border>
                    </Panel>
                </Border>
                
                <Border Grid.Row="2" Background="{DynamicResource ThemeSubPanelBrush}" Padding="15,8">
                    <TextBlock Text="{Binding TelemetryText}" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="12" HorizontalAlignment="Right"/>
                </Border>
            </Grid>
        </Grid>

        <!-- Settings Modal Overlay -->
        <Border Background="#80000000" IsVisible="{Binding IsSettingsOpen}" ZIndex="10">
            <Border Background="{DynamicResource ThemePanelBrush}" CornerRadius="12" Padding="25" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" BoxShadow="0 4 20 0 #40000000">
                <StackPanel Spacing="15">
                    <TextBlock Text="⚙️ Configuration &amp; Export Tools" FontWeight="Bold" Foreground="{DynamicResource ThemeAccentBlueBrush}" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    
                    <Border Background="{DynamicResource ThemeBorderBrush}" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="File Management" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontWeight="SemiBold" FontSize="14"/>
                            <Button Content="📁 Change Output Directory" Command="{Binding SelectDirectoryCommand}" Background="{DynamicResource ThemeAccentBlueBrush}" Foreground="{DynamicResource ThemeActionTextBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold"/>
                            <Button Content="📷 Save Manual Snapshot" Command="{Binding SaveSnapshotCommand}" Background="{DynamicResource ThemeAccentYellowBrush}" Foreground="{DynamicResource ThemeActionTextBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="{DynamicResource ThemeBorderBrush}" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Hardware Acceleration" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Execution Provider:" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            <ComboBox ItemsSource="{Binding AvailableHardware}" SelectedItem="{Binding SelectedHardware}" HorizontalAlignment="Stretch"/>
                            
                            <TextBlock Text="Camera Backend API:" Foreground="{DynamicResource ThemeTextPrimaryBrush}" Margin="0,15,0,0"/>
                            <ComboBox ItemsSource="{Binding AvailableCameraApis}" SelectedItem="{Binding SelectedCameraApi}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                    
                    <Button Content="Close" Command="{Binding CloseSettingsCommand}" Background="{DynamicResource ThemeAccentRedBrush}" Foreground="{DynamicResource ThemeActionTextBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Border>
    </Panel>
</Window>
